          }
        },

        {
          "name": "Revoke Roles from Admin User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/:id/roles",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", ":id", "roles"],
              "variable": [{ "key": "id", "value": "", "description": "Admin User UUID" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleIds\": [\n    \"<role-uuid>\"\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }

      ]
    }

  ]
}
